# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-django-secret-key
DJANGO_DEBUG=True
# Comma-separated. In production use your Render URL, e.g. hr-room.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/
MONGODB_DB_NAME=hr_dataroom

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ─── CORS ────────────────────────────────────────────────────────────────────
# In production: your Vercel URL, e.g. https://hr-system.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Gemini ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Supported: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash-lite
